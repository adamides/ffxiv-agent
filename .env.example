# FFLogs API credentials (client-credentials flow).
# Copy this file to `.env` and fill in your own values.
# Create a client at https://www.fflogs.com/api/clients/ (Public Client: unchecked).
# The real `.env` is gitignored — never commit it.
#
# Precedence: variables already set in your shell/environment win; this .env only
# fills in ones that are unset (the conventional dotenv behavior). So you can
# override any value with an env var (e.g. in CI) without editing this file.

FFLOGS_CLIENT_ID=your_client_id_here
FFLOGS_CLIENT_SECRET=your_client_secret_here
